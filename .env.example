# Server runtime keys
DASHSCOPE_API_KEY="your_dashscope_key"
DEEPSEEK_API_KEY="your_deepseek_key_optional"

# Qdrant vector DB URL
QDRANT_URL="http://localhost:6333"
QDRANT_AUTO_RECREATE="true"

# Python RAG microservice (required — Node proxies all RAG operations here)
RAG_SERVICE_URL="http://localhost:8000"
# LangChain 路径开关（与 rag_service 中 USE_LANGCHAIN 一致）
USE_LANGCHAIN="true"

# Optional app settings
DB_SEED_ON_STARTUP="false"

# Docker 一键启动时由 compose 覆盖为容器内地址，本地开发保持 localhost
# QDRANT_URL="http://localhost:6333"
# RAG_SERVICE_URL="http://localhost:8000"
# VITE_API_BASE="http://localhost:8080"

# Frontend API base — 指向 Node 主后端（8080），不是 Python RAG 服务
VITE_API_BASE="http://localhost:8080"

# Docker 默认管理员（compose 中 DB_SEED_ON_STARTUP=true 时自动创建）
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"
